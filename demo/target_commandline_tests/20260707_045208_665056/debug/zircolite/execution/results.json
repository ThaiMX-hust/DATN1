[{
  "title": "Curl Web Request With Potential Custom User-Agent",
  "id": "85de1f22-d189-44e4-8239-dc276b45379b",
  "description": "Detects execution of \"curl.exe\" with a potential custom \"User-Agent\". Attackers can leverage this to download or exfiltrate data via \"curl\" to a domain that only accept specific \"User-Agent\" strings",
  "sigmafile": "",
  "sigma": [
    "SELECT * FROM logs WHERE Channel='Microsoft-Windows-Sysmon/Operational' AND (EventID=1 AND (((Image LIKE '%\\\\curl.exe' ESCAPE '\\' OR OriginalFileName='curl.exe') AND (CommandLine REGEXP '(?i)(^|\\s|\")-H\\s*\"?\\s*User-Agent\\s*:' OR (CommandLine LIKE '%--header%' ESCAPE '\\' AND CommandLine LIKE '%User-Agent:%' ESCAPE '\\'))) OR ((Image LIKE '%\\\\curl.exe' ESCAPE '\\' OR OriginalFileName='curl.exe') AND (CommandLine LIKE '%--user-agent%' ESCAPE '\\' OR CommandLine REGEXP '(^|\\s|\")-A(\\s|\")'))))"
  ],
  "rule_level": "medium",
  "tags": [
    "attack.execution"
  ],
  "count": 1,
  "matches": [
    {
      "row_id": 2,
      "Channel": "Microsoft-Windows-Sysmon/Operational",
      "CommandLine": "curl.exe  -A \\\"EvilAgent\\\" http://example.com",
      "Company": "curl, https://curl.se/",
